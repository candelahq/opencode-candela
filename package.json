  "author": "Candela HQ",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/candelahq/opencode-candela.git"
  },
  "homepage": "https://candelahq.com",
  "bugs": {
    "url": "https://github.com/candelahq/opencode-candela/issues"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@opencode-ai/plugin": "latest",
    "@types/node": "^25.8.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "src/"
  ]
